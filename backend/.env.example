# LLM — DashScope (default) or AWS Bedrock OpenAI-compatible mantle endpoint.
# Bedrock: use a bedrock-api-key-… or ABSK… token as QWEN_API_KEY and set
# QWEN_BASE_URL to https://bedrock-mantle.<region>.api.aws/v1
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus
EXA_API_KEY=
FIRECRAWL_API_KEY=
DEMO_MODE=1

# Profile PII encryption at rest (required in production; auto-generated in DEMO_MODE).
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
PROFILE_ENCRYPTION_KEY=

# Optional TLS for encrypted profile data in transit (local dev).
# Generate certs: ./scripts/generate_dev_cert.sh
# Run: uvicorn app.main:app --ssl-keyfile=certs/key.pem --ssl-certfile=certs/cert.pem
SSL_KEYFILE=
SSL_CERTFILE=
FORCE_HTTPS=0
CORS_ORIGINS=http://localhost:5173,https://localhost:5173
